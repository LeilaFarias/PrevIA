    given-names: "Leila"
repository-code: "https://github.com/leilafarias/previa"
license: MIT
date-released: "2025-03-15"
keywords:
  - medicina preventiva
  - RAG
  - LangGraph
  - LangChain
  - MCP
  - saúde
  - inteligência artificial
  - NLP
